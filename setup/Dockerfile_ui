# setup/Dockerfile_ui
FROM python:3.11-slim

# Set working directory
WORKDIR /workspace

# Install system dependencies for performance and networking
RUN apt-get update && apt-get install -y \
    curl \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install uv for faster package management
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Note: Since this is a simple UI, we extract just the python requirements
RUN uv pip install --system streamlit requests pandas pyarrow

# Copy the source code
COPY ./src ./src

# Expose Streamlit port
EXPOSE 8501

# Run the app from the Home.py entry point
CMD ["streamlit", "run", "src/streamlit_interface/Home.py", "--server.port=8501", "--server.address=0.0.0.0"]